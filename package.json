{
  "name": "terminalhub",
  "version": "1.0.0",
  "description": "Terminal session manager - persistent terminal sessions with multi-client support",
  "main": "dist/index.js",
  "bin": {
    "th": "./bin/th"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest"
  },
  "keywords": [
    "terminal",
    "session",
    "multiplexer",
    "pty",
    "tmux",
    "screen"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "node-pty": "^1.0.0",
    "yargs": "^17.7.2",
    "@inquirer/prompts": "^7.0.0",
    "tsyringe": "^4.10.0",
    "reflect-metadata": "^0.2.2",
    "uuid": "^10.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^24.7.0",
    "@types/yargs": "^17.0.33",
    "@types/uuid": "^10.0.0",
    "vitest": "^4.0.3",
    "eslint": "^9.37.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "prettier": "^3.6.2"
  }
}
