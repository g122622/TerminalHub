{
  "name": "terminalhub",
  "version": "1.0.0",
  "description": "Terminal session manager - persistent terminal sessions with multi-client support",
  "main": "dist/index.js",
  "bin": {
    "th": "./bin/th"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:exe": "tsc && esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:node-pty && pkg dist/bundle.cjs --targets node20-win-x64 --output dist/th.exe --config package.json --fallback-to-source",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest"
  },
  "pkg": {
    "assets": [
      "node_modules/node-pty/prebuilds/**/*"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "terminal",
    "session",
    "multiplexer",
    "pty",
    "tmux",
    "screen"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "node-pty": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "uuid": "^10.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "@types/uuid": "^10.0.0",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.37.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  }
}
